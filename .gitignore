# ==================================================
# ATLAS-AI MONOREPO .gitignore
# Structure:
# atlas-ai/
# ├── ui       -> React + TypeScript
# ├── manager  -> Java Spring Boot
# └── core     -> FastAPI + LangGraph
# ==================================================

# ==================================================
# 🌍 GLOBAL OS / EDITOR GARBAGE
# ==================================================
.DS_Store
Thumbs.db
desktop.ini

.idea/
.vscode/
*.iml
*.ipr
*.iws

# Vim / misc editor junk
*.swp
*.swo
*~

# ==================================================
# 🔐 ENV / SECRETS
# ==================================================
.env
.env.*
*.local
*.secret
secrets.json

# ==================================================
# 📝 LOGS / TEMP / CACHE
# ==================================================
*.log
logs/
tmp/
temp/
.cache/

# ==================================================
# ⚛️ UI (React + TypeScript / Vite)
# Folder: /ui
# ==================================================
ui/node_modules/
ui/dist/
ui/build/
ui/.vite/
ui/.cache/

ui/npm-debug.log*
ui/yarn-debug.log*
ui/yarn-error.log*
ui/pnpm-debug.log*

# Test coverage
ui/coverage/

# ==================================================
# ☕ MANAGER (Java Spring Boot / Maven)
# Folder: /manager
# ==================================================
manager/target/
manager/out/
manager/build/

# Maven wrapper binary (optional)
manager/.mvn/wrapper/maven-wrapper.jar

# Java compiled files
*.class
*.jar
*.war
*.nar
*.ear

# JVM crash logs
hs_err_pid*

# Spring logs
manager/logs/
manager/*.log

# Local runtime data / DBs
manager/src/main/resources/data/*.db
manager/src/main/resources/data/*.sqlite
manager/src/main/resources/data/*.json
manager/src/main/resources/data/vault/

# ==================================================
# 🐍 CORE (FastAPI + LangGraph + Python)
# Folder: /core
# ==================================================

# Python cache
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
core/venv/
core/.venv/
core/env/

# Python tooling
core/.pytest_cache/
core/.mypy_cache/
core/.ruff_cache/
core/.coverage
core/htmlcov/

# LangGraph / runtime generated files
core/checkpoints/
core/saves/
core/**/*.db
core/**/*.sqlite

# Optional model caches
core/.cache/
core/models/
core/.ollama/

# FastAPI logs
core/*.log

# ==================================================
# 📦 Archives / Generated Packages
# ==================================================
*.zip
*.tar
*.tar.gz
*.rar
*.7z

# ==================================================
# 🚫 NEVER COMMIT THESE BY ACCIDENT
# ==================================================
*.pem
*.key
*.crt
*.p12
id_rsa
id_ed25519
