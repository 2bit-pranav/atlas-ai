# Compiled class file
*.class

# Log file
*.log

# BlueJ files
*.ctxt

# Mobile Tools for Java (J2ME)
.mtj.tmp/

# Package Files #
*.jar
*.war
*.nar
*.ear
*.zip
*.tar.gz
*.rar

# virtual machine crash logs, see http://www.java.com/en/download/help/error_hotspot.xml
hs_err_pid*

# End of https://mrkandreev.name/snippets/gitignore-generator/#Java

# =========================
# IDE garbage (IntelliJ / VS Code)
# =========================
atlas/.idea/
atlas/.vscode/
atlas/*.iml
atlas/*.ipr
atlas/*.iws

# =========================
# Maven / Java build output
# =========================
atlas/target/
atlas/out/
atlas/build/
atlas/.mvn/wrapper/maven-wrapper.jar

# =========================
# Logs
# =========================
atlas/*.log
atlas/logs/
atlas/**/logs/

# =========================
# OS-level nonsense
# =========================
atlas/.DS_Store
atlas/Thumbs.db
atlas/desktop.ini

# =========================
# Temporary / cache files
# =========================
atlas/tmp/
atlas/temp/
atlas/.cache/
atlas/**/.cache/

# =========================
# Environment / secrets
# =========================
atlas/.env
atlas/.env.*
atlas/**/.env
atlas/**/.env.*

# =========================
# Node / tooling (if any frontend sneaks in later)
# =========================
atlas/node_modules/
atlas/npm-debug.log*
atlas/yarn-error.log*

# =========================
# Compiled artifacts (just in case)
# =========================
atlas/**/*.class
atlas/**/*.jar
atlas/**/*.war
atlas/**/*.ear

# ==========================================
# 🌐 GLOBAL OS & IDE GARBAGE
# ==========================================
.DS_Store
Thumbs.db
desktop.ini
.idea/
.vscode/
*.iml
*.ipr
*.iws

# ==========================================
# 🔐 ENVIRONMENT VARIABLES & SECRETS
# ==========================================
.env
.env.*
*.local

# ==========================================
# 📝 LOGS & CACHE
# ==========================================
*.log
logs/
.cache/
tmp/
temp/

# ==========================================
# ⚛️ FRONTEND: atlas-ui (React / Vite)
# ==========================================
atlas-ui/node_modules/
atlas-ui/dist/
atlas-ui/dist-ssr/
atlas-ui/npm-debug.log*
atlas-ui/yarn-debug.log*
atlas-ui/yarn-error.log*

# ==========================================
# ☕ MANAGER: atlas-manager (Java / Spring Boot)
# ==========================================
atlas-manager/target/
atlas-manager/out/
atlas-manager/build/
atlas-manager/.mvn/wrapper/maven-wrapper.jar

# Compiled Java artifacts
*.class
*.jar
*.war
*.ear
hs_err_pid*

# 🛑 CRITICAL: Local Databases & Vaults (DO NOT COMMIT)
# Prevents committing locked DBs and personal PDF resumes
atlas-manager/src/main/resources/data/*.db
atlas-manager/src/main/resources/data/*.json
atlas-manager/src/main/resources/data/vault/

# ==========================================
# 🐍 WORKER: atlas-worker (Python / FastAPI)
# ==========================================
# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Virtual Environments
atlas-worker/venv/
atlas-worker/env/
atlas-worker/.venv/

# Tooling / Testing
atlas-worker/.pytest_cache/
atlas-worker/.mypy_cache/
atlas-worker/.coverage